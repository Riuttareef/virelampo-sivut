---
import Base from '../layouts/Base.astro';
import Cta from '../components/Cta.astro';
import { SITE } from '../config';

const includes = [
  "Enintään 4 m kylmäaineputkea",
  "Seinäläpivienti puuseinään",
  "Ulkoyksikön kiinnitys ja tärinävaimennus",
  "Kondenssiveden ohjaus",
  "Sähköistys (S2-pätevyys)",
  "Käytön ja huollon opastus",
];
const faq = [
  { q: "Kauanko asennus kestää?", a: "Tavallinen asennus valmistuu muutamassa tunnissa, useimmiten saman päivän aikana." },
  { q: "Saanko kotitalousvähennyksen?", a: "Kyllä, asennustyön osuudesta. Erittelemme työn osuuden laskuun valmiiksi vähennystä varten." },
  { q: "Sotkeeko poraus seinät?", a: "Ei. Käytämme laadukasta timanttiporausta, jolla läpivienti tehdään nopeasti ja pölyttömästi." },
  { q: "Mistä laite hankitaan?", a: "Voit ostaa laitteen itse tai yhteistyökumppanimme kautta – autamme tarvittaessa oikean mallin valinnassa." },
  { q: "Sopiiko ilmalämpöpumppu kerrostaloon?", a: "Kyllä, jäähdytyskäyttöön. Kerrostaloasunnoissa tarvitaan taloyhtiön lupa, ja yleensä sallitaan vain jäähdytys – ei lämmityskäyttöä. Autamme lupa-asiassa ja oikean laitteen valinnassa." },
];

// Service- ja FAQ-schema hakukoneille
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Ilmalämpöpumpun asennus",
    provider: { "@type": "HVACBusiness", name: SITE.name, "@id": `https://${SITE.domain}/#business` },
    areaServed: SITE.areaShort,
    description: "Ilmalämpöpumpun ammattiasennus kiinteällä hinnalla, Tukes-pätevä asentaja.",
    offers: { "@type": "Offer", priceCurrency: "EUR", price: SITE.basePriceFrom },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---
<Base title="Ilmalämpöpumpun asennus" description="Ilmalämpöpumpun ammattiasennus kiinteällä hinnalla. Siisti timanttiporaus, kotitalousvähennys huomioitu." schema={schema}>
  <section class="hero">
    <div class="container">
      <h1>Ilmalämpöpumpun asennus ammattitaidolla</h1>
      <p>Ammattitaitoinen asennus kiinteällä hinnalla. Saat siistin jäljen, oikean sijoituksen ja opastuksen käyttöön.</p>
      <div class="actions">
        <a href="/yhteys" class="btn btn--cta">Pyydä tarjous asennuksesta</a>
        {SITE.showPhone && <a href={SITE.phoneHref} class="btn btn--ghost">Soita {SITE.phone}</a>}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container prose">
      <p>Asennamme ilmalämpöpumput jäähdytykseen koteihin ja asuntoihin – ja lämmitykseen siellä missä se on sallittu. Olemme Tukes-päteviä, ja meillä on sähköalan S2-pätevyys sekä vahva kokemus pumppujen asennuksesta. Saat kiinteän hinnan etukäteen – ei yllätyslaskuja.</p>

      <h2 style="text-align:left">Perusasennukseen kuuluu</h2>
      <ul>
        {includes.map((i) => <li>{i}</li>)}
      </ul>
      <p class="note">Perusasennus alkaen <strong>{SITE.basePriceFrom} €</strong>. Kotitalousvähennyksen jälkeen nettohinta on selvästi alhaisempi – katso <a href="/hinnoittelu">hinnoittelu</a>.</p>

      <h2 style="text-align:left">Miksi valita meidät</h2>
      <ul>
        <li>Tukes-pätevyys ja vakuutus – pätevyyden voi tarkistaa rekisteristä</li>
        <li>Siisti asennustyö, joka ei sotke kotia</li>
        <li>Selkeä hinta etukäteen ja kotitalousvähennyksen ohjeistus</li>
        <li>Paikallinen, nopea ja joustava palvelu</li>
      </ul>

      <h2 style="text-align:left">Usein kysyttyä</h2>
      {faq.map((f) => (
        <div style="margin-bottom:14px">
          <h3 style="margin-bottom:.2em">{f.q}</h3>
          <p style="color:var(--muted)">{f.a}</p>
        </div>
      ))}
    </div>
  </section>

  <Cta title="Pyydä tarjous asennuksesta" />
</Base>
