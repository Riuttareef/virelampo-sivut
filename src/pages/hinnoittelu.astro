---
import Base from '../layouts/Base.astro';
import Cta from '../components/Cta.astro';
import { SITE } from '../config';

const rows = [
  ["Perusasennus", `alk. ${SITE.basePriceFrom} €`, "Vakioasennus ≤4 m putkea, läpivienti, kiinnitys, sähköistys, opastus"],
  ["Timanttiporaus (läpivienti)", "n. 350 €", "Siisti, pölytön läpivienti betoni-/tiiliseinään"],
  ["Lisäputki", "€/m sopimuksen mukaan", "Pidemmät putkivedot"],
  ["Lisätyöt", "tarjouksen mukaan", "Telineet, piippukotelot, sähkökeskustyöt"],
  ["Huolto", "alk. 150 €", "Puhdistus, suodattimet, toiminnan tarkistus"],
];
---
<Base title="Hinnoittelu ja kotitalousvähennys" description="Läpinäkyvä hinnoittelu ilmalämpöpumpun asennukseen pääkaupunkiseudulla. Kotitalousvähennys huomioitu.">
  <section class="hero">
    <div class="container">
      <h1>Hinnoittelu</h1>
      <p>Selkeät hinnat etukäteen – ja kotitalousvähennys kerrottuna valmiiksi.</p>
    </div>
  </section>

  <section class="section">
    <div class="container prose" style="max-width:820px">
      <table class="price">
        <thead><tr><th>Palvelu</th><th>Hinta</th><th>Sisältö</th></tr></thead>
        <tbody>
          {rows.map((r) => <tr><td><strong>{r[0]}</strong></td><td>{r[1]}</td><td style="color:var(--muted)">{r[2]}</td></tr>)}
        </tbody>
      </table>
      <p style="font-size:.9rem; color:var(--muted); margin-top:10px">Hinnat ovat suuntaa-antavia ja sisältävät alv:n. Saat aina tarkan, kiinteän hinnan tarjouksessa.</p>

      <h2 style="text-align:left">Näin hinta muodostuu</h2>
      <p>Asennushintaan vaikuttavat mm. putkivedon pituus, asennuskohteen kerros ja seinämateriaali sekä mahdolliset lisätyöt. Kerro tilanteesi tarjouspyynnössä, niin saat tarkan arvion.</p>

      <h2 style="text-align:left">Kotitalousvähennys</h2>
      <p>Voit hyödyntää kotitalousvähennyksen asennustyön osuudesta. Vuonna 2026 vähennys on jopa 40 % työn osuudesta (enintään 2 100 € / henkilö, 150 € omavastuu). Erittelen työn osuuden laskuun automaattisesti, jotta vähennyksen hakeminen on sinulle helppoa.</p>
      <p class="note">Tarkista voimassa oleva vähennysprosentti Verohallinnon sivuilta – muutamme tämän tiedon ajantasaiseksi ennen julkaisua.</p>
    </div>
  </section>

  <Cta />
</Base>
